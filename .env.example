# ─────────────────────────────────────────────────────────────────────────────
# Tokopedia MCP — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Authentication (required for orders & wishlist tools) ─────────────────────
#
# How to get these values:
#   1. Log in to https://www.tokopedia.com
#   2. Open DevTools (F12) → Application → Cookies → www.tokopedia.com
#   3. Find each cookie by name and paste its VALUE below
#

# Main session token — Cookie name: _SID_Tokopedia_
TOKO_SID=

# CAS authentication UUID — Cookie name: _UUID_CAS_
TOKO_UUID_CAS=

# Your numeric user ID — Cookie name: tuid
TOKO_USER_ID=

# Device fingerprint — Cookie name: DID
TOKO_DID=

# Device fingerprint (JS) — Cookie name: DID_JS  (optional but recommended)
TOKO_DID_JS=

# ── Optional Tuning ────────────────────────────────────────────────────────────

# Cache lifetime in milliseconds (default: 30000 = 30s)
CACHE_TTL_MS=30000

# Set to "true" to enable debug logging to stderr
DEBUG=false
