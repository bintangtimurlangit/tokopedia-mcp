{
  "name": "@bintangtimuralngit/tokopedia-mcp",
  "version": "1.0.0",
  "description": "A feature-rich MCP server for Tokopedia — search, product detail, shop info, orders, and wishlist",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bintangtimuralngit/tokopedia-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/bintangtimuralngit/tokopedia-mcp/issues"
  },
  "homepage": "https://github.com/bintangtimuralngit/tokopedia-mcp#readme",
  "bin": {
    "tokopedia-mcp": "./build/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node build/index.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "build",
    ".env.example",
    "docs",
    "CHANGELOG.md"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "tokopedia",
    "indonesia",
    "ecommerce",
    "marketplace"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.15.0",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
